path=(
  ~/bin
  ~/.local/bin
  /usr/local/bin
  /usr/local/sbin
  /bin
<% if node.dig('rbenv', 'enable') -%>
  ~/.rbenv/bin
<% end -%>
  /sbin
  /usr/bin
  /usr/libexec
  /usr/sbin
)
export LANG=<%= (@user.dig('locale') || node.locale) rescue node.locale %>
export LC_CTYPE=<%=(@user.dig('locale') || node.locale) rescue node.locale %>
export LC_ALL=<%= (@user.dig('locale') || node.locale) rescue node.locale %>
<% unless node.platform == 'freebsd' -%>
export RUBY_CONFIGURE_OPTS=--with-jemalloc
<% end -%>
<% if node.dig('nvm', 'enable') -%>
export NVM_DIR="$HOME/.nvm"
<% end -%>
<% if node.dig('rbenv', 'enable') -%>
<% unless node.platform == 'freebsd' -%>
export PATH="$HOME/.rbenv/bin:$PATH"
<% end -%>
eval "$(rbenv init -)"
<% end -%>
