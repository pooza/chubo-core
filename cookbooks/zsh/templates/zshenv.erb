path=(
  ~/bin
  ~/.local/bin
  /usr/local/bin
  /usr/local/sbin
  /bin
<% if node.dig('rbenv', 'enable') -%>
  ~/.rbenv/bin
<% end -%>
  /sbin
  /usr/bin
  /usr/libexec
  /usr/sbin
)
export LANG=<%= (@user.dig('locale') || node.locale) rescue node.locale %>
export LC_CTYPE=<%=(@user.dig('locale') || node.locale) rescue node.locale %>
export LC_ALL=<%= (@user.dig('locale') || node.locale) rescue node.locale %>
<% unless node.platform == 'freebsd' -%>
export RUBY_CONFIGURE_OPTS=--with-jemalloc
<% end -%>
<% if node.dig('nvm', 'enable') -%>
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
<% end -%>
<% if node.dig('rbenv', 'enable') && (node.platform != 'freebsd') -%>
export PATH="$HOME/.rbenv/bin:$PATH"
<% end -%>
# Ubuntu の rbenv は deploy ユーザーのホームにしか無いため、
# 他の wheel ユーザーでは rbenv が居ない。無条件に eval すると
# 全 zsh 起動時にエラーを吐き、itamae の stat 出力まで汚染する。
command -v rbenv > /dev/null && eval "$(rbenv init -)"
<% end -%>
