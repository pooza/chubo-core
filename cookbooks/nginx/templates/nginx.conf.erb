worker_processes 1;
<% if node.platform == 'freebsd' -%>
user www;
<% else -%>
user www-data;
<% end -%>

events {
  worker_connections 1024;
  multi_accept on;
}

http {
  include mime.types;
  default_type application/octet-stream;
  sendfile on;
  keepalive_timeout 70;
  client_max_body_size 0;
  gzip on;
  access_log off;
  error_log syslog:server=127.0.0.1,tag=nginx info;

  map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
  }

<% real_ip_from = node.dig('nginx', 'real_ip_from') || [] -%>
<% unless real_ip_from.empty? -%>
  # 前段に別の nginx が居る構成（ステージングの層2 = noah）では、$remote_addr が
  # 常にその前段になる。IP ベースの ACL とアクセスログのために、信頼できる前段から
  # 来た X-Forwarded-For で実クライアント IP を復元する。
  # ※ itamae のテンプレート評価では ActiveSupport が読まれないので present? は使えない。
<% real_ip_from.each do |addr| -%>
  set_real_ip_from <%= addr %>;
<% end -%>
  real_ip_header X-Forwarded-For;
  real_ip_recursive on;
<% end -%>

  server {
    listen 80;
    listen [::]:80;
    location / {
      root /var/www/html;
    }
  }

<% if node.platform == 'freebsd' -%>
  include /usr/local/etc/nginx/servers/*.conf;
<% else -%>
  include /etc/nginx/servers/*.conf;
<% end -%>
}
